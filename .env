# Sentry 密钥，用于加密 session 等数据
SENTRY_SECRET_KEY=78d1aa72e3c7acc06a7edf0923acc86c5770f4e6af31b8038b

# PostgreSQL 配置
POSTGRES_USER=sentry
POSTGRES_PASSWORD=sentry_password
POSTGRES_DB=sentry

# Sentry 管理员账号（首次初始化时使用）
SENTRY_ADMIN_EMAIL=admin@example.com
SENTRY_ADMIN_PASSWORD=admin123456

# Sentry 服务端口
SENTRY_PORT=9000

# Sentry URL Prefix (修复 CSRF 问题)
# 设置为你实际访问 Sentry 的地址
# 智能配置：如果设置为内网 IP (192.168.x.x/10.x.x.x/172.16-31.x.x)
# 会自动允许同一 C 段的所有 IP 访问，无需每次修改配置
# 示例：
#   - 本地访问: http://localhost:9000
#   - 内网访问: http://192.168.x.x:9000 (自动支持 192.168.x.1-254)
#   - 域名访问: http://sentry.yourdomain.com:9000
SENTRY_URL_PREFIX=http://192.168.8.89:9000
