<clickhouse>
  <logger>
    <!-- 日志级别：warning 减少输出量 -->
    <level>warning</level>
    <log>/var/log/clickhouse-server/clickhouse-server.log</log>
    <errorlog>/var/log/clickhouse-server/clickhouse-server.err.log</errorlog>
    <!-- 单个日志文件最大 100MB -->
    <size>100M</size>
    <!-- 最多保留 3 个轮转文件（总共最多 ~300MB） -->
    <count>3</count>
  </logger>
</clickhouse>
